{
  "name": "tmp",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "init-counter": "node -e \"const fs = require('fs'); if (!fs.existsSync('public/viewcounter.txt')) fs.writeFileSync('public/viewcounter.txt', '0');\"",
    "dev": "npm run init-counter && astro dev",
    "start": "astro dev",
    "build": "npm run init-counter && astro build",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "astro": "^6.4.6"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "prettier": "^3.1.1",
    "prettier-plugin-astro": "^0.12.3"
  }
}
